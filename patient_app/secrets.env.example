# Copy this file to secrets.env and add your Google Maps API key(s).
# Never commit secrets.env.
#
# Create keys: Google Cloud Console → APIs & Services → Credentials
# Enable "Maps SDK for iOS" and "Maps SDK for Android" on each key.
#
# Apply to native projects:
#   make -C mobile setup-maps-secrets
#
# Then full rebuild (not hot reload):
#   cd mobile/patient_app && flutter run --flavor dev --dart-define=APP_FLAVOR=dev

# One key for both platforms (simplest):
GOOGLE_MAPS_API_KEY=

# Or separate keys (uncomment and set instead of GOOGLE_MAPS_API_KEY):
# GOOGLE_MAPS_API_KEY_IOS=
# GOOGLE_MAPS_API_KEY_ANDROID=
